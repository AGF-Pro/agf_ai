FROM vespaengine/vespa:8.609.39

USER root

WORKDIR /opt/vespa

# Create directories at build time
RUN mkdir -p var/tmp var/db var/zookeeper logs \
    && chown -R vespa:vespa var logs \
    && chmod -R 777 var \
    && chmod -R 755 logs

ENV VESPA_SKIP_UPGRADE_CHECK=true

# Entrypoint script that fixes permissions at runtime (before volume is used)
COPY --chmod=755 entrypoint.sh /entrypoint.sh

EXPOSE 8080 8081 19071

ENTRYPOINT ["/entrypoint.sh"]