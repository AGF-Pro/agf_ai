# Variables de Entorno para Railway
# Copia estas variables en Railway UI > Variables o usa railway CLI

# ============================================
# SHARED VARIABLES (Todas los servicios)
# ============================================

# Authentication
AUTH_TYPE=disabled
# Para producción, cambia a:
# AUTH_TYPE=basic  # o 'oidc' para SSO
ENCRYPTION_KEY_SECRET=<generar-con-openssl-rand-base64-32>
# SESSION_EXPIRE_TIME_SECONDS=86400

# Email Domain Restriction (opcional)
# VALID_EMAIL_DOMAINS=tuempresa.com,otraempresa.com

# LLM Configuration
GEN_AI_MODEL_PROVIDER=openai
GEN_AI_MODEL_VERSION=gpt-4
FAST_GEN_AI_MODEL_VERSION=gpt-3.5-turbo
OPENAI_API_KEY=<tu-openai-api-key>

# Embedding Model
# Por defecto usa modelo local, pero puedes usar OpenAI:
# DOCUMENT_ENCODER_MODEL=text-embedding-3-small
# CROSS_ENCODER_MODEL_ENSEMBLE=

# Features
ENABLE_PAID_ENTERPRISE_EDITION_FEATURES=false
USE_LIGHTWEIGHT_BACKGROUND_WORKER=true

# File Storage (MinIO - configuración nativa de Onyx)
FILE_STORE_BACKEND=s3
S3_ENDPOINT_URL=http://${{minio.RAILWAY_PRIVATE_DOMAIN}}:9000
S3_AWS_ACCESS_KEY_ID=minioadmin
S3_AWS_SECRET_ACCESS_KEY=minioadmin
S3_FILE_STORE_BUCKET_NAME=onyx-file-store-bucket

# Alternativa: Usar PostgreSQL para storage (más simple pero menos performante)
# FILE_STORE_BACKEND=postgres

# Logging & Monitoring
LOG_LEVEL=info
DISABLE_TELEMETRY=true
# LOG_ONYX_MODEL_INTERACTIONS=false

# Web Domain (Railway proporciona esto automáticamente)
WEB_DOMAIN=${{RAILWAY_PUBLIC_DOMAIN}}

# ============================================
# API SERVER SPECIFIC
# ============================================

# Database Connection (Railway reference)
POSTGRES_HOST=${{Postgres.PGHOST}}
POSTGRES_USER=${{Postgres.PGUSER}}
POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}
POSTGRES_DB=${{Postgres.PGDATABASE}}
POSTGRES_PORT=${{Postgres.PGPORT}}

# Redis Connection (Railway reference)
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# Vespa Connection (Railway internal domain)
VESPA_HOST=${{vespa.RAILWAY_PRIVATE_DOMAIN}}

# Model Servers (Railway internal domains)
MODEL_SERVER_HOST=${{model-server-inference.RAILWAY_PRIVATE_DOMAIN}}
INDEXING_MODEL_SERVER_HOST=${{model-server-indexing.RAILWAY_PRIVATE_DOMAIN}}

# Storage Path
PERSISTENT_DOCUMENT_STORAGE_PATH=/app/file-system

# Port
PORT=8080

# ============================================
# BACKGROUND WORKER SPECIFIC
# ============================================
# (Hereda todas las variables de API Server +)

USE_LIGHTWEIGHT_BACKGROUND_WORKER=true
API_SERVER_PROTOCOL=https
API_SERVER_HOST=${{api-server.RAILWAY_PUBLIC_DOMAIN}}

# Celery Configuration (opcional)
# CELERY_WORKER_DOCFETCHING_CONCURRENCY=4
# CELERY_WORKER_DOCPROCESSING_CONCURRENCY=4
# CELERY_WORKER_LIGHT_CONCURRENCY=8

# Discord Bot (opcional)
# DISCORD_BOT_TOKEN=<token>
# DISCORD_BOT_INVOKE_CHAR=!

# ============================================
# WEB SERVER SPECIFIC
# ============================================

# Backend API URL (privada, dentro de Railway)
INTERNAL_URL=http://${{api-server.RAILWAY_PRIVATE_DOMAIN}}:8080

# Public API URL (para cliente)
NEXT_PUBLIC_API_URL=https://${{api-server.RAILWAY_PUBLIC_DOMAIN}}

# Theme (opcional)
# NEXT_PUBLIC_THEME=dark
# NEXT_PUBLIC_DISABLE_LOGOUT=false
# NEXT_PUBLIC_FORGOT_PASSWORD_ENABLED=true

PORT=3000

# ============================================
# VESPA SPECIFIC
# ============================================

VESPA_SKIP_UPGRADE_CHECK=true

# ============================================
# MODEL SERVERS SPECIFIC
# ============================================

# Inference Model Server
MIN_THREADS_ML_MODELS=4
LOG_LEVEL=info
PORT=8080

# Indexing Model Server (adicionales)
INDEXING_ONLY=true
VESPA_SEARCHER_THREADS=1

# ============================================
# ADVANCED / OPTIONAL
# ============================================

# Feature Flags
# SHOW_EXTRA_CONNECTORS=true
# DISABLE_MODEL_SERVER=false

# Analytics
# SENTRY_DSN=<tu-sentry-dsn>

# Nginx (no necesario en Railway)
# NGINX_PROXY_READ_TIMEOUT=300

# MCP Server (opcional)
# MCP_SERVER_ENABLED=false
# MCP_SERVER_PORT=8090

# Code Interpreter (beta)
# CODE_INTERPRETER_BETA_ENABLED=false

# ============================================
# CÓMO USAR ESTE ARCHIVO
# ============================================

# Método 1: Railway UI
# 1. Ve a tu proyecto en Railway
# 2. Selecciona cada servicio
# 3. Ve a Variables tab
# 4. Añade las variables correspondientes
# 5. Redeploy si es necesario

# Método 2: Railway CLI (recomendado para shared variables)
# railway variables set AUTH_TYPE=disabled
# railway variables set ENCRYPTION_KEY_SECRET="$(openssl rand -base64 32)"
# railway variables set OPENAI_API_KEY="sk-..."

# Método 3: Bulk import (si Railway lo soporta)
# railway variables bulk-set < env.railway.txt

# ============================================
# NOTAS IMPORTANTES
# ============================================

# 1. Las referencias ${{service.VARIABLE}} son específicas de Railway
# 2. Railway inyecta automáticamente DATABASE_URL, REDIS_URL, etc.
# 3. Algunas variables son compartidas, otras son por servicio
# 4. Variables sensibles (API keys) deben estar encriptadas en Railway
# 5. Usa Railway Secrets para datos muy sensibles
